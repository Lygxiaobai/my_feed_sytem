logs/
.run/
*.log
*.out
*.err
*.pid

# Backend local runtime files
backend/.run/

# Nginx local runtime state
nginx/runtime/

# Frontend dependencies and build outputs
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/

# Local env overrides
*.local
.env.local
.env.*.local
